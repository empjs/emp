{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s\\n' '[EMP] Preserve task scope and stop after verified completion.'",
            "async": false
          }
        ]
      }
    ]
  }
}
