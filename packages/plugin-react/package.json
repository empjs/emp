{
  "name": "@empjs/plugin-react",
  "version": "4.0.0-rc.2",
  "description": "emp react plugin",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "maintainers": [
    "xuhongbin",
    "ckken"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/empjs/emp.git",
    "directory": "packages/plugin-react"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rslib build --env-mode production",
    "dev": "rslib build --watch --env-mode development",
    "test": "pnpm run build && node test/react-refresh-plugin.test.mjs && node test/react-compiler-types.test.mjs && node test/react-compiler-output.test.mjs && node test/react-compiler-performance.test.mjs"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "author": "Ken",
  "devDependencies": {
    "@empjs/cli": "workspace:*",
    "@types/react": "^19.2.10"
  },
  "dependencies": {
    "@rspack/plugin-react-refresh": "^2.0.2",
    "@svgr/webpack": "8.1.0",
    "react-refresh": "0.18.0"
  }
}
