{
  "extends": "../tsconfig.rslib-bundler.json",
  "compilerOptions": {
    "lib": [
      "es2023",
      "DOM"
    ],
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "src/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}
