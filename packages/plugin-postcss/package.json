{
  "name": "@empjs/plugin-postcss",
  "version": "4.0.0-rc.4",
  "description": "emp postcss plugin",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "maintainers": [
    "xuhongbin",
    "ckken"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/empjs/emp.git",
    "directory": "packages/plugin-postcss"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "postcss"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rslib build --env-mode production",
    "dev": "rslib build --watch --env-mode development"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "author": "Ken",
  "devDependencies": {
    "@empjs/cli": "workspace:*"
  },
  "dependencies": {
    "postcss": "^8.4.38",
    "postcss-loader": "^8.2.1",
    "autoprefixer": "^10.4.19",
    "postcss-pxtorem": "^6.1.0"
  }
}
