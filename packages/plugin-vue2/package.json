{
  "name": "@empjs/plugin-vue2",
  "version": "4.0.0-alpha.3",
  "description": "emp vue2 plugin",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "maintainers": [
    "xuhongbin",
    "ckken"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/empjs/emp.git",
    "directory": "packages/plugin-vue2"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vue",
    "vue2"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rslib build --env-mode production",
    "dev": "rslib build --watch --env-mode development"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "author": "Ken",
  "devDependencies": {
    "@empjs/cli": "workspace:*"
  },
  "dependencies": {
    "@vue/babel-preset-jsx": "1.4.0",
    "babel-loader": "9.1.3",
    "vue": "2.7.14",
    "vue-loader": "15.11.0",
    "vue-svg-inline-loader": "2.1.5"
  }
}
