{
  "extends": "../tsconfig.rslib-bundler.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "src/*": [
        "./src/*"
      ]
    },
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "emitDeclarationOnly": true,
    "noUnusedLocals": false
  },
  "include": [
    "src"
  ]
}
