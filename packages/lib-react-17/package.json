{
  "name": "@empjs/lib-react",
  "version": "0.17.0",
  "description": "empShare runtime",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "maintainers": [
    "xuhongbin",
    "ckken",
    "doerme"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/empjs/emp.git",
    "directory": "packages/plugin-emp-runtime"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/runtime.umd.js",
  "module": "dist/runtime.js",
  "types": "dist/runtime.d.ts",
  "exports": {
    ".": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs",
      "default": "./dist/runtime.umd.js"
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      },
      "default": "./dist/runtime.umd.js"
    },
    "./*": [
      "./*",
      "./*.d.ts"
    ]
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "scripts": {
    "dev": "rslib build --watch --env-mode development",
    "dev:development": "rslib build --watch --env-mode development --lib runtime-umd-development",
    "dev:production": "rslib build --watch --env-mode production --lib runtime-umd-production",
    "build": "rslib build --env-mode production",
    "build:development": "rslib build --env-mode development --lib runtime-umd-development",
    "build:production": "rslib build --env-mode production --lib runtime-umd-production",
    "dev:serve": "serve ./dist --cors -p 1700",
    "start": "serve ./dist --cors -p 1700"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "author": "Ken",
  "dependencies": {
    "@empjs/module-federation-runtime": "^0.6.2",
    "@module-federation/runtime": "0.6.1",
    "@module-federation/sdk": "0.6.1",
    "history": "^5.3.0",
    "react": "17",
    "react-dom": "17",
    "react-router-dom": "^6.25.1"
  },
  "devDependencies": {
    "@empjs/cli": "workspace:*",
    "@swc/core": "^1.7.4",
    "@types/react": "17",
    "@types/react-dom": "17",
    "cross-env": "^7.0.3",
    "rimraf": "^5.0.5"
  }
}
