{
  "name": "@empjs/share",
  "version": "4.0.0",
  "description": "emp share and runtime",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "output"
  ],
  "maintainers": [
    "ckken@qq.com"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/empjs/emp.git",
    "directory": "packages/emp-share"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    },
    "./mfRuntime": {
      "types": "./dist/mfRuntime.d.ts",
      "import": "./dist/mfRuntime.js",
      "default": "./dist/mfRuntime.js"
    },
    "./forceRemote": {
      "types": "./dist/forceRemote.d.ts",
      "import": "./dist/forceRemote.js",
      "default": "./dist/forceRemote.js"
    },
    "./sdk": {
      "types": "./dist/sdk.d.ts",
      "import": "./dist/sdk.js",
      "default": "./dist/sdk.js"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "import": "./dist/adapter.js",
      "default": "./dist/adapter.js"
    },
    "./adapterVue": {
      "types": "./dist/adapterVue.d.ts",
      "import": "./dist/adapterVue.js",
      "default": "./dist/adapterVue.js"
    },
    "./rspack": {
      "types": "./dist/rspack.d.ts",
      "import": "./dist/rspack.js",
      "default": "./dist/rspack.js"
    },
    "./library": {
      "types": "./output/sdk.d.ts",
      "default": "./output/sdk.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "default": "./dist/vue.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ],
      "runtime": [
        "./dist/runtime.d.ts"
      ],
      "mfRuntime": [
        "./dist/mfRuntime.d.ts"
      ],
      "sdk": [
        "./dist/sdk.d.ts"
      ],
      "forceRemote": [
        "./dist/forceRemote.d.ts"
      ],
      "adapter": [
        "./dist/adapter.d.ts"
      ],
      "adapterVue": [
        "./dist/adapterVue.d.ts"
      ],
      "rspack": [
        "./dist/rspack.d.ts"
      ],
      "library": [
        "./output/sdk.d.ts"
      ],
      "react": [
        "./dist/react.d.ts"
      ],
      "vue": [
        "./dist/vue.d.ts"
      ]
    }
  },
  "scripts": {
    "dev": "pnpm --filter @empjs/share run /^dev:.*/",
    "dev:lib-dev": "rslib build --watch --env-mode development",
    "dev:serve": "node ../../scripts/static-services.mjs start --service emp-share",
    "build": "rslib build --env-mode production",
    "test": "pnpm run build && node test/module-federation-deps.test.mjs && node test/dts-runtime-pkgs.test.mjs && node test/version-isolation.test.mjs && node test/esm-only-publish.test.mjs && node test/rspack/plugin-share-config.test.mjs && node test/rspack/force-remotes-config.test.mjs && node test/runtime/package-exports-runtime.test.mjs",
    "start": "node ../../scripts/static-services.mjs start --service emp-share",
    "https": "node ../../scripts/static-services.mjs start --service emp-share --https"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "author": "Ken",
  "dependencies": {
    "@module-federation/rspack": "^2.8.0",
    "@module-federation/runtime": "^2.8.0",
    "@module-federation/runtime-tools": "^2.8.0",
    "@module-federation/sdk": "^2.8.0",
    "core-js": "^3.46.0"
  },
  "devDependencies": {
    "@empjs/cli": "workspace:*",
    "@swc/core": "^1.15.43"
  }
}
