{
  "name": "@empjs/plugin-stylus",
  "version": "4.0.0-alpha.1",
  "description": "emp stylus plugin",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "maintainers": [
    "xuhongbin",
    "ckken",
    "doerme"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/empjs/emp.git",
    "directory": "packages/plugin-vue2"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
