{
  "extends": "../tsconfig.rslib-nodenext.json",
  "compilerOptions": {
    "lib": [
      "es2023",
      "DOM"
    ],
    "outDir": "dist",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "paths": {
      "src/*": [
        "./src/*"
      ]
    },
    "rootDir": "src"
  },
  "include": [
    "src"
  ]
}
