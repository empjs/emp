{
  "name": "@empjs/plugin-vue3",
  "version": "4.0.0-rc.1",
  "description": "emp vue3 plugin",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "maintainers": [
    "xuhongbin",
    "ckken"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/empjs/emp.git",
    "directory": "packages/plugin-vue3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vue",
    "vue3"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rslib build --env-mode production",
    "dev": "rslib build --watch --env-mode development"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "author": "Ken",
  "devDependencies": {
    "@empjs/cli": "workspace:*"
  },
  "dependencies": {
    "@babel/preset-typescript": "7.27.1",
    "@empjs/vue-loader": "17.4.5",
    "@vue/babel-plugin-jsx": "1.5.0",
    "babel-loader": "10.0.0",
    "vue": "3.5.20",
    "vue-svg-loader": "0.16.0"
  }
}
