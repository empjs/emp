{
  "extends": "@empjs/cli/tsconfig/react",
  "compilerOptions": {
    "paths": {
      "src/*": [
        "./src/*"
      ],
      "*": [
        "./@mf-types/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "~@/*": [
        "./src/*"
      ]
    },
    "plugins": [
      {
        "name": "typescript-plugin-css-modules",
        "options": {
          "additionalData": "@import '~@/css/mixin';",
          "allowUnknownClassnames": true
        },
        "postcssOptions": {
          "useConfig": true
        }
      }
    ]
  },
  "include": [
    "src"
  ]
}
