{
  "extends": "@empjs/cli/tsconfig/vue",
  "compilerOptions": {
    "lib": [
      "ES2016",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "preserve",
    "allowJs": true,
    "skipLibCheck": true,
    "types": [
      "@empjs/cli/types/vue"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
