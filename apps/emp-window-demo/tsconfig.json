{
  "extends": "@empjs/cli/tsconfig/react",
  "compilerOptions": {
    "paths": {
      "src/*": [
        "./src/*"
      ],
      "*": [
        "./@mf-types/*"
      ],
      "react": [
        "./node_modules/@types/react"
      ],
      "react-dom": [
        "./node_modules/@types/react-dom"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "@mf-types"
  ]
}
